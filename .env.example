# ─── Staging / agency multi-tenant ───────────────────────────
STAGING_MODE=false
STAGING_LOGIN_EMAIL="test@cleartg.ua"
STAGING_LOGIN_PASSWORD="cleartg123"
# Email оператора агентства (ADMIN у всіх кабінетах клієнтів)
