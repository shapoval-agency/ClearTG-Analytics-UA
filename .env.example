# ─── Email (magic link + agency invites) ─────────────────────
SMTP_HOST=""
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ClearTG <noreply@cleartg.ua>"
