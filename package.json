{
  "name": "cleartg-analytics-ua",
  "version": "0.1.0",
  "private": true,
  "description": "ClearTG Analytics UA — honest Telegram ad analytics for Ukraine",
  "scripts": {
    "dev": "pnpm --parallel --filter @cleartg/api --filter @cleartg/web dev",
    "dev:tunnel": "node scripts/dev-tunnel.mjs",
    "dev:api": "pnpm --filter @cleartg/api dev",
    "dev:web": "pnpm --filter @cleartg/web dev",
    "build": "pnpm --filter @cleartg/web build",
    "build:all": "pnpm run -r build",
    "build:web": "pnpm --filter @cleartg/web build",
    "build:vercel": "pnpm --filter @cleartg/web build",
    "test": "pnpm run -r test",
    "lint": "pnpm run -r lint",
    "db:generate": "pnpm --filter @cleartg/database generate",
    "db:migrate": "pnpm --filter @cleartg/database migrate:dev",
    "db:push": "pnpm --filter @cleartg/database push",
    "db:studio": "pnpm --filter @cleartg/database studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "staging:up": "docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml down",
    "staging:logs": "docker compose -f docker-compose.staging.yml logs -f"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
